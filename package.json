{
  "name": "flezta-api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --watch src src/server.ts",
    "build": "tsc && cp -R src/views dist/views && cp -R src/public dist/public",
    "start": "node dist/server.js",
    "generate:token": "ts-node firebase.client.ts",
    "seed:products": "ts-node ./dev-scripts/seedProducts.ts",
    "seed:category": "ts-node ./dev-scripts/seedCategory-v2.ts",
    "postinstall": "npx puppeteer browsers install chrome"
  },
